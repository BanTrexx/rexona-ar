<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rexona x FIFA Booth</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }

      body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        width: 100%;
        background-color: #000000;
      }

      .main-container {
        position: relative;
        height: 100vh;
        aspect-ratio: 9 / 16;
        overflow: hidden;
        background-color: #06241a;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .bg-layer {
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        z-index: 0;
      }

      .bg-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.9;
        background-color: #06241a;
      }

      .bg-gradient {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 50%;
        background: linear-gradient(to top, #06241a, transparent);
      }

      .content-layer {
        position: relative;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        height: 100%;
        flex: 1;
      }

      .logo-container {
        position: absolute;
        top: 154px;
        left: 311px;
      }

      .btn-container {
        position: absolute;
        top: 669px;
        left: 245px;
      }

      .img-auto {
        max-width: none;
        width: auto;
        height: auto;
      }

      .spacer {
        flex: 1;
      }

      .bottom-area {
        width: 100%;
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .players-container {
        margin-bottom: 50px;
        position: relative;
        z-index: 10;
      }

      .drop-shadow-2xl {
        filter: drop-shadow(0 25px 25px rgba(0, 0, 0, 0.15));
      }

      .hashtag-container {
        position: absolute;
        top: auto;
        bottom: 90px;
        z-index: 20;
      }

      .drop-shadow-lg {
        filter: drop-shadow(0 10px 8px rgba(0, 0, 0, 0.04))
          drop-shadow(0 4px 3px rgba(0, 0, 0, 0.1));
      }
    </style>
  </head>
  <body>
    <main class="main-container">
      <div class="bg-layer">
        <img src="/images/bg.png" alt="Background" class="bg-image" />
        <div class="bg-gradient"></div>
      </div>

      <div class="content-layer">
        <div class="logo-container">
          <img src="/images/fifa.png" alt="FIFA x Rexona" class="img-auto" />
        </div>

        <div class="btn-container">
          <a href="/select">
            <img src="/images/btn.png" alt="btn-take-photo" class="img-auto" />
          </a>
        </div>

        <div class="spacer"></div>

        <div class="bottom-area">
          <div class="players-container">
            <img
              src="/images/comp1.png"
              alt="Football Players"
              class="img-auto drop-shadow-2xl"
            />
          </div>

          <div class="hashtag-container">
            <img
              src="/images/setia.png"
              alt="#SETIASETIAAAPSAAT"
              class="img-auto drop-shadow-lg"
            />
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
